{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "../.vercel/output/functions",
    "rootDir": "..",
    "baseUrl": "..",
    "paths": {
      "../src/*": ["src/*"]
    },
    "skipLibCheck": true,
    "strict": false
  },
  "include": ["./**/*.ts", "../src/**/*.ts"]
}
