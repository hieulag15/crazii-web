# ===== Telegram Bot Config (set các biến này trên Vercel) =====
# Lấy token từ @BotFather (NHỚ revoke token cũ đã lộ và tạo token mới!)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Chat ID của channel. Cách lấy:
#  1. Thêm bot vào channel làm admin
#  2. Gửi 1 tin nhắn bất kỳ vào channel
#  3. Mở: https://api.telegram.org/bot<TOKEN>/getUpdates
#  4. Tìm "chat":{"id":-100xxxxxxxxxx} -> đó là CHAT_ID
TELEGRAM_CHAT_ID=-1001234567890

# (Tùy chọn) chuỗi bí mật chống spam endpoint /api/notify và /api/scan
NOTIFY_SECRET=
