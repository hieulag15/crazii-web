{
  "regions": ["sin1"],
  "functions": {
    "api/auto-scan.ts": {
      "includeFiles": "src/**",
      "maxDuration": 60
    },
    "api/**/*.ts": {
      "includeFiles": "src/**",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
